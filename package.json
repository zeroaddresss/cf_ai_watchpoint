{
	"name": "cf_ai_watchpoint",
	"version": "0.0.0",
	"private": true,
	"scripts": {
		"deploy": "wrangler deploy",
		"dev": "wrangler dev",
		"start": "wrangler dev",
		"build:ui": "vite build",
		"check": "tsc --noEmit",
		"test": "npm run test:worker && npm run test:ui",
		"test:worker": "npm run test:worker:index && npm run test:worker:capture",
		"test:worker:index": "vitest --config vitest.config.mts --maxWorkers=1 --minWorkers=1 test/index.spec.ts",
		"test:worker:capture": "vitest --config vitest.config.mts --maxWorkers=1 --minWorkers=1 test/capture.spec.ts",
		"test:ui": "vitest --config vitest.ui.config.mts",
		"test:e2e": "playwright test",
		"test:e2e:headed": "playwright test --headed",
		"test:mcp:remote": "node scripts/test-remote-mcp.mjs",
		"cf-typegen": "wrangler types"
	},
	"devDependencies": {
		"@cloudflare/vitest-pool-workers": "^0.12.4",
		"@playwright/test": "1.58.2",
		"@testing-library/jest-dom": "6.9.1",
		"@testing-library/react": "16.3.2",
		"@types/node": "25.3.5",
		"@types/react": "19.2.14",
		"@types/react-dom": "19.2.3",
		"jsdom": "28.1.0",
		"typescript": "^5.5.2",
		"viem": "2.47.0",
		"vitest": "~3.2.0",
		"wrangler": "4.71.0"
	},
	"dependencies": {
		"@cloudflare/puppeteer": "1.0.6",
		"@modelcontextprotocol/sdk": "1.26.0",
		"@tailwindcss/vite": "4.2.1",
		"@vitejs/plugin-react": "5.1.4",
		"@x402/core": "2.6.0",
		"@x402/evm": "2.6.0",
		"@x402/hono": "2.6.0",
		"@x402/mcp": "2.6.0",
		"agents": "0.7.5",
		"class-variance-authority": "0.7.1",
		"clsx": "2.1.1",
		"hono": "4.12.5",
		"lucide-react": "0.577.0",
		"radix-ui": "1.4.3",
		"react": "19.2.4",
		"react-dom": "19.2.4",
		"tailwind-merge": "3.5.0",
		"tailwindcss": "4.2.1",
		"tw-animate-css": "1.4.0",
		"vite": "7.3.1",
		"zod": "4.3.6"
	}
}
